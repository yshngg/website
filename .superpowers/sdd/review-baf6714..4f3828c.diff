diff --git a/templates/blog-post.html b/templates/blog-post.html
new file mode 100644
index 0000000..d90fe63
--- /dev/null
+++ b/templates/blog-post.html
@@ -0,0 +1,45 @@
+{% extends "base.html" %}
+{% block title %}{{ page.title }} — {{ config.title }}{% endblock %}
+{% block og_title %}{{ page.title }} — {{ config.title }}{% endblock %}
+{% block twitter_title %}{{ page.title }}{% endblock %}
+{% block content %}
+
+<h1 class="title">{{ page.title }}</h1>
+
+<div class="post-meta">
+  <span><strong>{{ page.date }}</strong></span>
+  {% set words = page.word_count | default(value=page.content | split(pat=" ") | length) %}
+  {% set minutes = (words / 200) | round(method="ceil") | int %}
+  {% if minutes < 1 %}{% set minutes = 1 %}{% endif %}
+  <span class="reading-time">{{ minutes }} min read</span>
+  {% if page.taxonomies.category %}
+  {% for cat in page.taxonomies.category %}
+  <a class="badge-taxonomy" href="{{ get_taxonomy_url(kind="category", name=cat, lang=lang) }}">{{ cat }}</a>
+  {% endfor %}
+  {% endif %}
+  {% if page.taxonomies.tags %}
+  {% for tag in page.taxonomies.tags %}
+  <a class="badge-taxonomy" href="{{ get_taxonomy_url(kind="tags", name=tag, lang=lang) }}">#{{ tag }}</a>
+  {% endfor %}
+  {% endif %}
+</div>
+
+<div class="post-layout">
+  <div class="post-content content">{{ page.content | safe }}</div>
+  <div class="post-toc">{% include "toc.html" %}</div>
+</div>
+
+<nav class="post-nav">
+  {% if page.later %}
+  <a href="{{ page.later.permalink | safe }}">&larr; {{ page.later.title }}</a>
+  {% else %}
+  <span></span>
+  {% endif %}
+  {% if page.earlier %}
+  <a href="{{ page.earlier.permalink | safe }}">{{ page.earlier.title }} &rarr;</a>
+  {% else %}
+  <span></span>
+  {% endif %}
+</nav>
+
+{% endblock content %}
